# =============================================================================
# Environment Variables for Jupyter Data Engineering Container
# =============================================================================
# Copy this file to .env and update values as needed
# NEVER commit .env files with real credentials to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Jupyter Configuration
# -----------------------------------------------------------------------------
JUPYTER_TOKEN=
JUPYTER_ENABLE_LAB=yes

# -----------------------------------------------------------------------------
# Database Connections (examples)
# -----------------------------------------------------------------------------
# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=jupyter
POSTGRES_PASSWORD=jupyter_password
POSTGRES_DB=dataeng

# Generic database URL format
DATABASE_URL=postgresql://jupyter:jupyter_password@postgres:5432/dataeng

# -----------------------------------------------------------------------------
# Cloud Provider Credentials (examples - use secrets management in production)
# -----------------------------------------------------------------------------
# AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# GCP
# GOOGLE_APPLICATION_CREDENTIALS=/home/jupyter/.gcp/credentials.json

# Azure
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
TZ=UTC
