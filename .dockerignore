# =============================================================================
# Docker Ignore File
# =============================================================================
# Excludes files from the Docker build context
# This speeds up builds and prevents sensitive data from being included
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
ENV/
env/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example
secrets/
*.pem
*.key

# -----------------------------------------------------------------------------
# Documentation and Misc
# -----------------------------------------------------------------------------
*.md
!README.md
LICENSE
Makefile
docs/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker/

# -----------------------------------------------------------------------------
# Data files (don't include large data in image)
# -----------------------------------------------------------------------------
*.csv
*.parquet
*.json
!config.json
data/
*.db
*.sqlite

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
.cache/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Test files
# -----------------------------------------------------------------------------
tests/
test/
*_test.py
test_*.py
.pytest_cache/
.coverage
htmlcov/
